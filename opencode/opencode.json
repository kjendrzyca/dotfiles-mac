{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "plugin": [
    "opencode-gemini-auth@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "@slkiser/opencode-quota@latest",
    "opencode-with-claude@latest"
  ],
  "experimental": {
    "quotaToast": {
      "enableToast": false
    }
  },
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "http://127.0.0.1:3456",
        "apiKey": "dummy"
      }
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.4"
    },
    "plan": {
      "model": "openai/gpt-5.4"
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ]
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": false
    }
  },
  "permission": {
    "bash": {
      "gh search *": "allow",
      "gh repo view *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh issue create *": "ask",
      "gh issue close *": "ask",
      "gh issue edit *": "ask",
      "gh issue delete *": "ask",
      "gh pr create *": "ask",
      "gh pr close *": "ask",
      "gh pr merge *": "ask",
      "gh pr edit *": "ask",
      "gh pr review *": "ask",
      "gh repo create *": "ask",
      "gh repo delete *": "ask",
      "gh release create *": "ask",
      "gh release delete *": "ask",
      "git add *": "allow",
      "git commit *": "allow",
      "git push *": "ask",
      "git pull *": "ask",
      "rm *": "ask",
      "npx *": "ask",
      "npm exec *": "ask",
      "pnpm dlx *": "ask",
      "bunx *": "ask",
      "yarn dlx *": "ask"
    }
  }
}
