# Ignore everything by default
*

# Whitelist specific folders and files below
# Use !folder/ to unignore a folder
# Use !folder/** to unignore all contents recursively

# Whitelist skhd
!skhd/
!skhd/**

# Whitelist yabai
!yabai/
!yabai/**

# Whitelist sketchybar
!sketchybar/
!sketchybar/**

# Whitelist aerospace
!aerospace/
!aerospace/**

# Whitelist kitty
!kitty/
!kitty/**
# Whitelist karabiner config
!karabiner/
karabiner/*
!karabiner/karabiner.json
# Whitelist opencode config
!opencode/
opencode/*
!opencode/opencode.json
!opencode/tui.json
!opencode/commands/
opencode/commands/*
!opencode/commands/deslop.md
opencode/skills/
opencode/plugins/
opencode/node_modules/
opencode/package.json
opencode/package-lock.json
opencode/bun.lock
opencode/.gitignore

# Whitelist .gitignore itself
!.gitignore
!.secrets.baseline
!.pre-commit-config.yaml
!README.md

# Re-ignore sensitive/temporary files even if in whitelisted folders
**/.venv/
**/.DS_Store
**/debug/
**/.window_focus_state
**/.window_order_state.json
**/bak/
**/*.backup
sketchybar/__pycache__/aerospace_windows_service.cpython-314.pyc

# Defense in depth: keep known-sensitive local configs ignored
stripe/
gh/
op/
